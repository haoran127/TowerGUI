# ==============================
# Node.js
# ==============================
node_modules/
pnpm-debug.log*
*.tsbuildinfo

# ==============================
# Build outputs (可由源码重新生成)
# ==============================
packages/*/dist/
apps/*/TsProject/output/
apps/unity-demo/Assets/Resources/main.mjs

# ==============================
# Unity — 自动生成的缓存和临时文件
# ==============================
apps/*/Library/
apps/*/Temp/
apps/*/Logs/
apps/*/UserSettings/
apps/*/obj/
apps/*/Build/
apps/*/Builds/
apps/*/MemoryCaptures/
apps/*/Recording/

# Unity crash reports
sysinfo.txt
crashlytics-build.properties

# ==============================
# Unity — 第三方插件二进制（体积大，用户自行安装）
# ==============================
apps/unity-demo/PuertsDL/

# TextMesh Pro 包资产（由 Unity Package Manager 自动恢复）
**/Assets/TextMesh Pro/

# ==============================
# 第三方参考代码（非本项目产物）
# ==============================
docs/github/

# ==============================
# Preview cache
# ==============================
.tower-preview/

# ==============================
# Generated prefabs (rebuild from .tower.json)
# ==============================
**/GeneratedPrefabs/
**/Assets/GeneratedPrefabs/

# ==============================
# IDE / OS
# ==============================
.vs/
.vscode/
.idea/
*.suo
*.user
*.csproj
*.sln
*.swp
*~
.DS_Store
Thumbs.db

# ==============================
# 临时测试 / 导入 / 工具输出
# ==============================
_test_import/
current.tower.json
_golden-test.tower.json
tools/_output/

# ==============================
# 第三方客户端代码（非本项目产物）
# ==============================
apps/lfclient/
apps/uwclient/
apps/UIActivity/
apps/UIBackpack/
apps/unity-demo/uw_new/
apps/unity-demo/TsProject/src/lfgame/
apps/unity-demo/Assets/123.unity
apps/unity-demo/Assets/123.unity.meta

# ==============================
# 敏感文件
# ==============================
.env
.env.*
